@page "/"
@using AutoDokas.Resources
@using Schema.NET

<PageTitle>@Text.HomeTitle</PageTitle>

<HeadContent>
    <meta name="description" content="Automobilio pirkimo pardavimo sutartis internetu. Užpildykite, pasirašykite ir atsisiųskite - greitai, saugiai, be spausdintuvo." />
    <link rel="canonical" href="https://autodokas.lt/" />
    <meta property="og:title" content="Automobilio pirkimo pardavimo sutartis internetu | AutoDokas" />
    <meta property="og:description" content="Automobilio pirkimo pardavimo sutartis internetu. Užpildykite, pasirašykite ir atsisiųskite - greitai, saugiai, be spausdintuvo." />
    <meta property="og:url" content="https://autodokas.lt/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AutoDokas" />
</HeadContent>

@((MarkupString)_jsonLd)

<!-- Hero Section -->
<section class="hero">
    <div class="hero-bg">
        <div class="hero-orb hero-orb--1"></div>
        <div class="hero-orb hero-orb--2"></div>
        <div class="hero-grid"></div>
    </div>
    <div class="container">
        <div class="row align-items-center min-vh-hero">
            <div class="col-lg-7 hero-col">
                <p class="hero-eyebrow">AutoDokas.lt</p>
                <h1 class="hero-heading">@Text.HeroTitle</h1>
                <p class="hero-desc">@Text.HeroSubtitle</p>
                <div class="d-flex flex-wrap gap-3 justify-content-center justify-content-lg-start">
                    <a href="/contract" class="btn-hero">
                        @Text.SellNowButton
                        <i class="bi bi-arrow-right"></i>
                    </a>
                    <a href="/demo" class="btn-hero btn-hero--outline">
                        Kaip veikia
                        <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-flex justify-content-center">
                <div class="hero-visual">
                    <img src="img/car.png" alt="" class="hero-car" />
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Service Description Section -->
<section class="service-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <h2 class="section-heading">@Text.ServiceDescriptionHeading</h2>
                <p class="service-desc">@Text.ServiceDescription</p>
            </div>
        </div>
    </div>
</section>

<!-- How It Works Section -->
<section class="how-section">
    <div class="container">
        <div class="text-center mb-5">
            <p class="section-label">@Text.HowItWorksTitle</p>
            <h2 class="section-heading">@Text.HowItWorksSubtitle</h2>
        </div>
        <div class="steps-row">
            <div class="steps-line"></div>
            <div class="row g-4 justify-content-center">
                <div class="col-md-4">
                    <div class="step">
                        <div class="step-num">01</div>
                        <div class="step-icon">
                            <i class="bi bi-pencil-square"></i>
                        </div>
                        <h3 class="step-title">@Text.Step1Title</h3>
                        <p class="step-text">@Text.Step1Text</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="step">
                        <div class="step-num">02</div>
                        <div class="step-icon">
                            <i class="bi bi-vector-pen"></i>
                        </div>
                        <h3 class="step-title">@Text.Step2Title</h3>
                        <p class="step-text">@Text.Step2Text</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="step">
                        <div class="step-num">03</div>
                        <div class="step-icon">
                            <i class="bi bi-file-earmark-pdf"></i>
                        </div>
                        <h3 class="step-title">@Text.Step3Title</h3>
                        <p class="step-text">@Text.Step3Text</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center mt-5">
            <a href="/contract" class="btn-hero">
                @Text.StartNow
                <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="feat-section">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-heading">@Text.FeaturesTitle</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feat">
                    <div class="feat-icon">
                        <i class="bi bi-lightning-charge-fill"></i>
                    </div>
                    <h3 class="feat-title">@Text.Feature1Title</h3>
                    <p class="feat-text">@Text.Feature1Text</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feat">
                    <div class="feat-icon">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <h3 class="feat-title">@Text.Feature2Title</h3>
                    <p class="feat-text">@Text.Feature2Text</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feat">
                    <div class="feat-icon">
                        <i class="bi bi-phone-fill"></i>
                    </div>
                    <h3 class="feat-title">@Text.Feature3Title</h3>
                    <p class="feat-text">@Text.Feature3Text</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FAQ Section -->
<section class="faq-section">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-heading">@Text.FaqHeading</h2>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="accordion" id="faqAccordion">
                    <div class="accordion-item">
                        <h3 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">@Text.Faq1Question</button>
                        </h3>
                        <div id="faq1" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">@((MarkupString)Text.Faq1Answer)</div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h3 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">@Text.Faq2Question</button>
                        </h3>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">@((MarkupString)Text.Faq2Answer)</div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h3 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">@Text.Faq3Question</button>
                        </h3>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">@((MarkupString)Text.Faq3Answer)</div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h3 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">@Text.Faq4Question</button>
                        </h3>
                        <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">@((MarkupString)Text.Faq4Answer)</div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h3 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq5">@Text.Faq5Question</button>
                        </h3>
                        <div id="faq5" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">@((MarkupString)Text.Faq5Answer)</div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h3 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq6">@Text.Faq6Question</button>
                        </h3>
                        <div id="faq6" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">@((MarkupString)Text.Faq6Answer)</div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h3 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq7">@Text.Faq7Question</button>
                        </h3>
                        <div id="faq7" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">@((MarkupString)Text.Faq7Answer)</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="bottom-cta">
    <div class="bottom-cta-orb"></div>
    <div class="container position-relative">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <h2 class="bottom-cta-heading">@Text.CtaTitle</h2>
                <p class="bottom-cta-desc">@Text.CtaSubtitle</p>
                <a href="/contract" class="btn-hero btn-hero--light">
                    @Text.StartNow
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</section>

@code {
    private string _jsonLd = string.Empty;

    protected override void OnInitialized()
    {
        var organization = new Organization
        {
            Name = "AutoDokas",
            Url = new Uri("https://autodokas.lt"),
        };

        var webSite = new WebSite
        {
            Name = "AutoDokas",
            Url = new Uri("https://autodokas.lt"),
            InLanguage = "lt",
        };

        var webPage = new WebPage
        {
            Name = "Automobilio pirkimo pardavimo sutartis internetu | AutoDokas",
            Description = "Automobilio pirkimo pardavimo sutartis internetu. Užpildykite, pasirašykite ir atsisiųskite - greitai, saugiai, be spausdintuvo.",
            Url = new Uri("https://autodokas.lt/"),
            InLanguage = "lt",
            IsPartOf = webSite,
        };

        var service = new Service
        {
            Name = "Automobilio pirkimo pardavimo sutarties sudarymas internetu",
            Description = "Internetinė paslauga automobilio pirkimo pardavimo sutarčiai sudaryti, pasirašyti ir atsisiųsti PDF formatu.",
            Url = new Uri("https://autodokas.lt/"),
            Broker = organization,
            ServiceType = "Automobilio pirkimo pardavimo sutarties sudarymas",
            AreaServed = "Lietuva",
        };

        var faqPage = new FAQPage
        {
            Name = Text.FaqHeading,
            MainEntity = new OneOrMany<IThing>(new List<IThing>
            {
                new Question { Name = Text.Faq1Question, AcceptedAnswer = new Answer { Text = StripHtml(Text.Faq1Answer) } },
                new Question { Name = Text.Faq2Question, AcceptedAnswer = new Answer { Text = StripHtml(Text.Faq2Answer) } },
                new Question { Name = Text.Faq3Question, AcceptedAnswer = new Answer { Text = StripHtml(Text.Faq3Answer) } },
                new Question { Name = Text.Faq4Question, AcceptedAnswer = new Answer { Text = StripHtml(Text.Faq4Answer) } },
                new Question { Name = Text.Faq5Question, AcceptedAnswer = new Answer { Text = StripHtml(Text.Faq5Answer) } },
                new Question { Name = Text.Faq6Question, AcceptedAnswer = new Answer { Text = StripHtml(Text.Faq6Answer) } },
                new Question { Name = Text.Faq7Question, AcceptedAnswer = new Answer { Text = StripHtml(Text.Faq7Answer) } },
            }),
        };

        var schemas = new Thing[] { organization, webSite, webPage, service, faqPage };
        var jsonParts = schemas.Select(s => s.ToHtmlEscapedString());
        _jsonLd = string.Join("\n", jsonParts.Select(j =>
            $"<script type=\"application/ld+json\">{j}</script>"));
    }

    private static string StripHtml(string html)
    {
        return System.Text.RegularExpressions.Regex.Replace(html, "<[^>]+>", "");
    }
}
